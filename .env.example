NODE_ENV=development
PORT=4000
# 允许多个域名，英文逗号分隔；支持 *.vercel.app 通配
CORS_ORIGIN=http://localhost:3000,https://your-frontend.vercel.app,*.vercel.app

# 前端 API 基地址（不要带 /api）
# 本地开发：
NUXT_PUBLIC_API_BASE=http://localhost:4000
# 线上示例（Vercel 前端 + 独立 API 服务）：
# NUXT_PUBLIC_API_BASE=https://your-api-domain.com

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Optional: only use this on trusted server-side code. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=

NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
